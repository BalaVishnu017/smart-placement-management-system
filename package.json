{
  "name": "smart-placement-management-system",
  "version": "1.0.0",
  "description": "Smart Campus Placement Management System",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build:client": "npm run build --workspace=client",
    "start:server": "npm start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
